# Server Configuration
PORT=5001
NODE_ENV=development

# Database Configuration
# Format: mongodb+srv://<username>:<password>@<cluster>/<database>
MONGO_URI=mongodb+srv://dummy_user:dummy_password@cluster0.example.mongodb.net/streamify_db?retryWrites=true&w=majority

# GetStream.io API Credentials (Streaming & Chat)
STREAM_API_KEY=your_stream_api_key_here
STREAM_API_SECRET=your_stream_api_secret_here

# Authentication
# Suggestion: Use a 32-character random string for production
JWT_SECRET_KEY=super_secret_dummy_key_12345

# Cache Configuration
REDIS_URL=redis://127.0.0.1:6379