```bash
# This must be the Stream API key (the public API key), not the secret.
# It should match the backend's STREAM_API_KEY value.
# Example: VITE_STREAM_API_KEY=<your_stream_api_key>
VITE_STREAM_API_KEY=k4sdyaqj6sk5
# This should be the base URL of your backend API.
# Example: VITE_BACKEND_URL=http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000
```